{
  "name": "ClubKit",
  "tree": {
    "$className": "DataModel",
    "ReplicatedStorage": {
      "$path": "src/shared",
      "$ignoreUnknownInstances": true
    },
    "ServerScriptService": {
      "$path": "src/server",
      "$ignoreUnknownInstances": true
    },
    "ServerStorage": {
      "$path": "src/serverStorage",
      "$ignoreUnknownInstances": true
    },
    "StarterPlayer": {
      "StarterPlayerScripts": {
        "$path": "src/client",
        "$ignoreUnknownInstances": true
      }
    },
    "Workspace": {
      "$properties": {
        "FilteringEnabled": true
      }
    },
    "Lighting": {
      "$properties": {
        "Ambient": [
          0,
          0,
          0
        ],
        "Brightness": 2,
        "GlobalShadows": true,
        "Outlines": false,
        "Technology": "Voxel"
      }
    },
    "SoundService": {
      "$properties": {
        "RespectFilteringEnabled": true
      }
    }
  }
}